flowchart TD
    A[data/songs.csv] --> B[load_songs]
    B --> C[List of song dictionaries]
    D[src/main.py USER_PROFILES ACTIVE_USER] --> E[user_prefs]
    C --> F[recommend_songs user_prefs songs k]
    E --> F

    F --> G[for each song]
    G --> H[_song_score_details computes similarities]
    H --> I[genre mood energy acoustic valence similarities]
    I --> J[score_song points]

    J --> J1[genre points = 2.0 * genre_score]
    J --> J2[mood points = 1.5 * mood_score]
    J --> J3[energy points = 1.0 * energy_score]
    J --> J4[acoustic points = 0.5 * acoustic_score]
    J --> J5[valence points = 0.5 * valence_score]

    J1 --> K[base score]
    J2 --> K
    J3 --> K
    J4 --> K
    J5 --> K

    K --> N{recent_songs exists and artist not recent}
    N -->|yes| O[add 0.1 novelty bonus]
    N -->|no| P[keep base score]
    O --> Q[append scored row]
    P --> Q

    Q --> R[sort scored rows descending]
    R --> S[artist diversity pass subtract 0.05 per seen artist]
    S --> T[re-sort descending]
    T --> U[slice top k]
    U --> V[build explanation from reasons]
    V --> W[return list song score explanation]
